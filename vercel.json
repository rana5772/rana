{
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://blogs.rana.net.in/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/((?!api/|static/|_next/|[\\w-]+\\.\\w+).*)",
      "destination": "/index.html"
    }
  ]
}
